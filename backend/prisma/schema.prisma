generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  event_organizer
  admin
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  competitive
}

enum Language {
  th
  en
}

enum SessionStatus {
  open
  full
  ongoing
  completed
  cancelled
}

enum SessionSource {
  manual
  from_invite
}

enum RoomType {
  match
  session
  event
}

enum ReportCategory {
  fake_profile
  inappropriate_chat
  no_show
  harassment
  inappropriate_content
}

enum ReportContextType {
  swipe
  chat
  session
}

enum ReportStatus {
  pending
  approved
  rejected
}

enum InviteStatus {
  pending
  accepted
  rejected
}

enum SwipeDirection {
  left
  right
}

// ---------- Core ----------

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  nickname      String?
  role          Role     @default(user)
  language      Language @default(th)
  noShowCount   Int      @default(0) @map("no_show_count")
  warningBadge  Boolean  @default(false) @map("warning_badge")
  hasEquipment  Boolean  @default(false) @map("has_equipment")
  qrToken       String   @unique @map("qr_token")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  photos            ProfilePhoto[]
  sports            UserSport[]
  weeklySchedule    WeeklySchedule[]
  favoritePlaces    FavoritePlace[]
  sessions          UserSession[]
  swipesGiven       Swipe[]              @relation("SwipesGiven")
  swipesReceived    Swipe[]              @relation("SwipesReceived")
  matchesAsUserA    Match[]              @relation("MatchUserA")
  matchesAsUserB    Match[]              @relation("MatchUserB")
  blockedByMe       BlockedUser[]        @relation("BlockerUser")
  blockedMe         BlockedUser[]        @relation("BlockedTargetUser")
  messages          Message[]
  hostedSessions    SportSession[]       @relation("SessionHost")
  sessionMembership SportSessionMember[]
  sentInvites       SportInvite[]        @relation("InviteSender")
  receivedInvites   SportInvite[]        @relation("InviteReceiver")
  reportsFiled      Report[]             @relation("Reporter")
  reportsAgainstMe  Report[]             @relation("ReportedUser")
  organizedEvents   Event[]              @relation("EventOrganizer")
  eventMembership   EventMember[]
  eventAnnouncements EventAnnouncement[] @relation("AnnouncementAuthor")
  achievements      UserAchievement[]
  notifications     Notification[]

  @@map("users")
}

model ProfilePhoto {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profile_photos")
}

model Sport {
  id   String @id @default(uuid())
  name String @unique
  icon String @default("🏅")

  users    UserSport[]
  sessions SportSession[]
  invites  SportInvite[]
  events   Event[]

  @@map("sports")
}

model UserSport {
  userId  String     @map("user_id")
  sportId String     @map("sport_id")
  level   SkillLevel

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([userId, sportId])
  @@index([sportId])
  @@map("user_sports")
}

model WeeklySchedule {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  dayOfWeek Int    @map("day_of_week") // 0-6
  startTime String @map("start_time")  // HH:mm
  endTime   String @map("end_time")    // HH:mm

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("weekly_schedules")
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  placeId   String?  @map("google_place_id")
  photoUrl  String?  @map("photo_url")
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now()) @map("created_at")

  favoritedBy FavoritePlace[]
  sessions    SportSession[]
  invites     SportInvite[]
  events      Event[]

  @@map("venues")
}

model FavoritePlace {
  userId  String @map("user_id")
  venueId String @map("venue_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([userId, venueId])
  @@index([venueId])
  @@map("favorite_places")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  deviceInfo   String?  @map("device_info")
  ip           String?
  loginAt      DateTime @default(now()) @map("login_at")
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ---------- Swipe & Match ----------

model Swipe {
  id         String         @id @default(uuid())
  swiperId   String         @map("swiper_id")
  swipedId   String         @map("swiped_id")
  direction  SwipeDirection
  createdAt  DateTime       @default(now()) @map("created_at")

  swiper User @relation("SwipesGiven", fields: [swiperId], references: [id], onDelete: Cascade)
  swiped User @relation("SwipesReceived", fields: [swipedId], references: [id], onDelete: Cascade)

  @@unique([swiperId, swipedId])
  @@index([swipedId])
  @@map("swipes")
}

model Match {
  id        String   @id @default(uuid())
  userAId   String   @map("user_a_id")
  userBId   String   @map("user_b_id")
  createdAt DateTime @default(now()) @map("created_at")

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  invites SportInvite[]

  @@unique([userAId, userBId])
  @@map("matches")
}

model BlockedUser {
  blockerId String @map("blocker_id")
  targetId  String @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  target  User @relation("BlockedTargetUser", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([blockerId, targetId])
  @@map("blocked_users")
}

// ---------- Chat ----------

model Message {
  id        String    @id @default(uuid())
  senderId  String    @map("sender_id")
  roomType  RoomType  @map("room_type")
  roomId    String    @map("room_id")
  content   String?
  imageUrl  String?   @map("image_url")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomType, roomId, createdAt])
  @@map("messages")
}

// ---------- Sport Session ----------

model SportSession {
  id              String        @id @default(uuid())
  hostUserId      String        @map("host_user_id")
  sportId         String        @map("sport_id")
  venueId         String        @map("venue_id")
  title           String
  description     String?
  skillLevel      SkillLevel    @map("skill_level")
  equipmentRequired Boolean     @default(false) @map("equipment_required")
  maxPlayers      Int           @map("max_players")
  currentPlayers  Int           @default(1) @map("current_players")
  startTime       DateTime      @map("start_time")
  endTime         DateTime      @map("end_time")
  status          SessionStatus @default(open)
  source          SessionSource @default(manual)
  inviteId        String?       @unique @map("invite_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  host    User          @relation("SessionHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  sport   Sport         @relation(fields: [sportId], references: [id])
  venue   Venue         @relation(fields: [venueId], references: [id])
  invite  SportInvite?  @relation(fields: [inviteId], references: [id])
  members SportSessionMember[]

  @@index([sportId])
  @@index([venueId])
  @@index([status])
  @@index([startTime])
  @@map("sport_sessions")
}

model SportSessionMember {
  id          String    @id @default(uuid())
  sessionId   String    @map("session_id")
  userId      String    @map("user_id")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  leftAt      DateTime? @map("left_at")
  leaveReason String?   @map("leave_reason")
  kicked      Boolean   @default(false)

  session SportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
  @@map("sport_session_members")
}

// ---------- Sport Invite ----------

model SportInvite {
  id          String       @id @default(uuid())
  matchId     String       @map("match_id")
  senderId    String       @map("sender_id")
  receiverId  String       @map("receiver_id")
  sportId     String       @map("sport_id")
  venueId     String       @map("venue_id")
  date        DateTime
  maxPlayers  Int          @map("max_players")
  message     String?
  status      InviteStatus @default(pending)
  createdAt   DateTime     @default(now()) @map("created_at")
  respondedAt DateTime?    @map("responded_at")

  match    Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender   User    @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User    @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sport    Sport   @relation(fields: [sportId], references: [id])
  venue    Venue   @relation(fields: [venueId], references: [id])
  session  SportSession?

  @@index([receiverId])
  @@map("sport_invites")
}

// ---------- No Show & Report ----------

model Report {
  id               String            @id @default(uuid())
  reporterId       String            @map("reporter_id")
  reportedUserId   String            @map("reported_user_id")
  category         ReportCategory
  description      String?
  evidenceUrl      String?           @map("evidence_url")
  contextType      ReportContextType @map("context_type")
  contextId        String            @map("context_id")
  status           ReportStatus      @default(pending)
  adminNote        String?           @map("admin_note")
  resolvedAt       DateTime?         @map("resolved_at")
  createdAt        DateTime          @default(now()) @map("created_at")

  reporter     User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId])
  @@index([status])
  @@map("reports")
}

// ---------- Event ----------

model Event {
  id            String   @id @default(uuid())
  organizerId   String   @map("organizer_id")
  sportId       String   @map("sport_id")
  venueId       String   @map("venue_id")
  title         String
  description   String?
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  maxCapacity   Int?     @map("max_capacity")
  coverUrl      String?  @map("cover_url")
  coverPosX     Float?   @default(50) @map("cover_pos_x")
  coverPosY     Float?   @default(50) @map("cover_pos_y")
  images        String[] @default([])
  createdAt     DateTime @default(now()) @map("created_at")

  organizer     User                @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  sport         Sport               @relation(fields: [sportId], references: [id])
  venue         Venue               @relation(fields: [venueId], references: [id])
  members       EventMember[]
  announcements EventAnnouncement[]

  @@index([sportId])
  @@index([venueId])
  @@index([startTime])
  @@map("events")
}

model EventAnnouncement {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  authorId  String   @map("author_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author User  @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_announcements")
}

model EventMember {
  id          String    @id @default(uuid())
  eventId     String    @map("event_id")
  userId      String    @map("user_id")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  checkedInAt DateTime? @map("checked_in_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_members")
}

// ---------- Achievement ----------

model Achievement {
  id          String @id @default(uuid())
  name        String
  description String?
  icon        String?
  conditions  Json

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

// ---------- Notification ----------

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  payload   Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
