# Railway Postgres — copy from Railway dashboard: Project > Postgres > Connect > "Postgres Connection URL"
# Use the *public* URL for local dev; Railway also injects a private DATABASE_URL automatically when deployed on Railway itself.
DATABASE_URL="postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway"

PORT=4000
NODE_ENV=development

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
QR_SECRET="change-me-qr"

# Comma-separated list to allow multiple frontends, e.g. dev + LAN IP + prod domain
CORS_ORIGIN="http://localhost:5173,http://192.168.1.10:5173"

# Optional: Upstash Redis for caching (NFR-P04)
REDIS_URL=""

# Optional: Cloudinary (PRO-01, CHT-03)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
